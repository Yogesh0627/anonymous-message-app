# ---- Database ----
# MongoDB connection string (Atlas or local).
MONGOOSE_URI="mongodb://localhost:27017/candor"

# ---- Auth (NextAuth) ----
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ---- SEO ----
# Public site origin used for canonical URLs, Open Graph tags, robots.txt and
# sitemap.xml. Set this to your deployed domain in production (no trailing slash).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Comma-separated emails granted the admin role on sign-in (bootstrap the first
# admin without editing the database). Further admins can be promoted in the UI.
ADMIN_EMAILS="you@example.com"

# ---- Google OAuth (optional) ----
# From https://console.cloud.google.com → APIs & Services → Credentials →
# OAuth client ID (Web). Redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
# If unset, the "Continue with Google" button is simply not wired up.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---- Email (Resend) ----
# Get a key at https://resend.com
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# Sender for transactional emails. Default only reaches your own Resend account
# email; point at a verified domain (noreply@yourdomain.com) to email anyone.
EMAIL_FROM="onboarding@resend.dev"

# ---- AI (Google Gemini) ----
# Free key from https://aistudio.google.com/app/apikey
# Optional: AI features (suggestions, composer, coach, moderation) degrade
# gracefully if unset.
GOOGLE_GENERATIVE_AI_API_KEY="your-gemini-api-key"

# ---- Scale infra (optional) ----
# Upstash Redis REST — enables shared rate limiting, caching, and AI quotas
# across instances. If unset, an in-memory fallback is used (single-instance).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# Base per-user daily AI-call budget (default 50).
DAILY_AI_CALLS="50"

# ---- Demo / Guest login (optional, public) ----
# Prefills the "Guest Login" button on the sign-in page. Never put a real
# personal account here — create a dedicated demo account.
NEXT_PUBLIC_GUEST_EMAIL="demo@example.com"
NEXT_PUBLIC_GUEST_PASSWORD="Demo!Pass123"
